<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green-1:#0d8a6e;--green-2:#1aab8a;--green-3:#3dbea0;
  --primary:#1aab8a;--primary-light:#3dbea0;--primary-deep:#0d8a6e;
  --primary-glow:rgba(26,171,138,0.22);
  --text:#0d1a12;--text-mid:#166b57;--text-muted:#5a9e8a;
  --bg:#f0f7f4;--card-bg:#ffffff;--border:#c2e8da;--border-dark:#7dcab5;
  --danger:#c0392b;--danger-light:#fdecea;
}
body{font-family:'Tajawal',sans-serif;background:linear-gradient(135deg,#eef8f4,#dff4ec);min-height:100vh;padding:30px 0 60px;position:relative;overflow-x:hidden}
body::before,body::after{content:'';position:fixed;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:0}
body::before{width:500px;height:500px;background:radial-gradient(circle,rgba(26,171,138,0.12),transparent 70%);top:-100px;right:-150px;animation:blobMove 12s ease-in-out infinite alternate}
body::after{width:400px;height:400px;background:radial-gradient(circle,rgba(13,138,110,0.1),transparent 70%);bottom:-80px;left:-100px;animation:blobMove 15s ease-in-out infinite alternate-reverse}
@keyframes blobMove{from{transform:translate(0,0) scale(1)}to{transform:translate(30px,20px) scale(1.08)}}
.grid-overlay{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(26,171,138,0.035) 1px,transparent 1px),linear-gradient(90deg,rgba(26,171,138,0.035) 1px,transparent 1px);background-size:40px 40px}
.container{max-width:720px;margin:0 auto;padding:0 20px;position:relative;z-index:1}

/* LETTERHEAD */
.letterhead{background:#fff;border-radius:10px 10px 0 0;border:1px solid var(--border);border-bottom:none;padding:28px 36px;display:flex;align-items:center;justify-content:space-between;gap:20px;position:relative;overflow:hidden;box-shadow:0 4px 24px rgba(26,171,138,0.08);animation:slideDown .6s cubic-bezier(.22,1,.36,1) both}
.letterhead::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--primary),var(--primary-light),var(--primary));background-size:200% 100%;animation:shimmer 3s linear infinite}
@keyframes shimmer{from{background-position:200% 0}to{background-position:-200% 0}}
.letterhead-right{display:flex;align-items:center;gap:16px}
.org-seal{
  width:100px;
  height:100px;
  border-radius:90px;
  border:3.5px solid rgba(26,171,138,0.18);
  background:rgba(255,255,255,0.72);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  box-shadow:
    0 10px 30px rgba(13,138,110,0.10),
    inset 0 1px 0 rgba(255,255,255,0.65);
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  overflow:hidden;
  transition:all .3s ease;
}

.org-seal:hover{
  transform:translateY(-2px) scale(1.02);
  box-shadow:
    0 14px 34px rgba(13,138,110,0.14),
    inset 0 1px 0 rgba(255,255,255,0.7);
}

.org-seal img{
  width:62%;
  height:62%;
  object-fit:contain;
  display:block;
  filter:drop-shadow(0 3px 8px rgba(13,138,110,0.10));
}
/* HERO BANNER */
.hero-banner{background:linear-gradient(135deg,#0e6e57 0%,var(--primary) 45%,var(--primary-light) 100%);padding:36px 36px 32px;position:relative;overflow:hidden}
.hero-banner::before{content:'';position:absolute;width:280px;height:280px;border-radius:50%;border:40px solid rgba(255,255,255,0.06);top:-100px;left:-60px}
.hero-banner::after{content:'';position:absolute;width:160px;height:160px;border-radius:50%;border:28px solid rgba(255,255,255,0.05);bottom:-60px;right:40px}
.hero-inner{position:relative;z-index:1;display:flex;align-items:center;gap:20px}
.hero-icon-wrap{width:60px;height:60px;border-radius:16px;background:rgba(255,255,255,0.14);border:1.5px solid rgba(255,255,255,0.22);display:grid;place-items:center;flex-shrink:0;animation:pulse 2.5s ease-in-out infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,255,255,0.18)}50%{box-shadow:0 0 0 10px rgba(255,255,255,0)}}
.hero-icon-wrap i{font-size:24px;color:#fff}
.hero-text{flex:1}
.hero-title{font-size:26px;font-weight:900;color:#fff;line-height:1.3;letter-spacing:-.5px}
.hero-title .accent{color:#ffe08a}

/* DOC CARD */
.doc-card{background:#fff;border:1px solid var(--border);border-top:none;border-radius:0 0 20px 20px;padding:36px 36px 32px;box-shadow:0 8px 40px rgba(26,171,138,0.09);margin-bottom:20px;animation:slideUp .6s .15s cubic-bezier(.22,1,.36,1) both}

/* PROMO CARD */
.promo-notification{width:100%;background:linear-gradient(135deg,var(--green-1) 0%,var(--green-2) 55%,var(--green-3) 100%);border-radius:24px;padding:28px 22px 24px;position:relative;overflow:hidden;text-align:center;box-shadow:0 18px 45px rgba(26,171,138,0.28);border:2px solid rgba(255,255,255,0.18);margin-bottom:28px}
.promo-notification::before,.promo-notification::after{content:'';position:absolute;border-radius:50%;background:rgba(255,255,255,0.08);pointer-events:none}
.promo-notification::before{width:180px;height:180px;top:-60px;right:-50px}
.promo-notification::after{width:140px;height:140px;bottom:-50px;left:-40px}
.promo-badge-pill{position:relative;z-index:2;display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.14);color:#fff;padding:8px 14px;border-radius:999px;font-size:13px;font-weight:800;border:1px solid rgba(255,255,255,0.2);margin-bottom:18px}
.gift-wrap{width:120px;height:120px;margin:0 auto 16px;position:relative;z-index:2;display:grid;place-items:center;animation:shakeGift 1s ease-in-out infinite;transform-origin:center bottom}
.gift-box{width:100px;height:80px;background:#fff;border-radius:18px;position:relative;box-shadow:0 10px 24px rgba(0,0,0,0.14)}
.gift-box::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:16px;height:100%;background:linear-gradient(180deg,var(--green-2),var(--green-1));border-radius:10px}
.gift-box::after{content:'';position:absolute;top:24px;left:0;width:100%;height:14px;background:linear-gradient(90deg,var(--green-2),var(--green-3))}
.gift-lid{position:absolute;top:-16px;left:50%;transform:translateX(-50%);width:112px;height:24px;background:#fff;border-radius:14px;box-shadow:0 6px 14px rgba(0,0,0,0.10)}
.gift-lid::before,.gift-lid::after{content:'';position:absolute;top:-18px;width:26px;height:26px;border:7px solid #fff;border-radius:50% 50% 0 50%}
.gift-lid::before{left:27px;transform:rotate(-35deg)}
.gift-lid::after{right:27px;transform:scaleX(-1) rotate(-35deg)}
@keyframes shakeGift{0%,100%{transform:rotate(0deg)}15%{transform:rotate(-8deg)}30%{transform:rotate(8deg)}45%{transform:rotate(-6deg)}60%{transform:rotate(6deg)}75%{transform:rotate(-3deg)}}
.promo-title{position:relative;z-index:2;color:#fff;font-size:28px;font-weight:900;margin-bottom:10px}
.promo-text{position:relative;z-index:2;color:rgba(255,255,255,0.92);font-size:15px;line-height:1.9;font-weight:500;margin-bottom:18px}
.promo-code-box{position:relative;z-index:2;background:#fff;border:2px dashed var(--green-2);border-radius:20px;padding:16px 20px;display:inline-flex;flex-direction:column;align-items:center;gap:8px;min-width:230px;box-shadow:0 10px 22px rgba(0,0,0,0.10);margin-bottom:16px}
.promo-code-label{font-size:12px;font-weight:800;color:var(--green-1);letter-spacing:1px}
.promo-code{font-size:28px;font-weight:900;color:var(--green-2);letter-spacing:3px;direction:ltr}
.copy-btn{display:inline-flex;align-items:center;gap:7px;background:var(--green-2);color:#fff;border:none;border-radius:10px;padding:8px 18px;font-family:'Tajawal',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;margin-top:4px}
.copy-btn:hover{background:var(--green-1);transform:scale(1.04)}
.copy-btn.copied{background:var(--green-3)}
.promo-note{position:relative;z-index:2;font-size:13px;font-weight:700;color:rgba(255,255,255,0.78);margin-top:4px}
.official-footer{border-top:1px solid var(--border);padding-top:18px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--text-muted);font-weight:500;flex-wrap:wrap;gap:10px;margin-top:32px}
.official-footer .ministry{display:flex;align-items:center;gap:6px}
.official-footer .ministry i{color:var(--primary-light);font-size:11px}
@keyframes slideDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:600px){
  .letterhead{padding:20px 18px;flex-direction:column;align-items:flex-start;gap:14px;border-radius:16px 16px 0 0}
  .hero-banner{padding:24px 20px}
  .hero-title{font-size:20px}
  .doc-card{padding:24px 18px;border-radius:0 0 16px 16px}
  .promo-code{font-size:22px;letter-spacing:2px}
  .promo-code-box{min-width:100%}
  .promo-notification{padding:24px 16px 20px}
  .promo-title{font-size:24px}
}
</style>
</head>
<body>
<div class="grid-overlay"></div>
<div class="container">
    <!-- LETTERHEAD -->
    <div class="letterhead">
      <div class="letterhead-right">
        <div class="org-seal">
          <img src="data:image/png;base64," alt="تكسي ناقل">
        </div>
      <div>
        <div class="org-name">تكسي ناقل</div>
        <div class="org-sub"><i class="fa fa-shield-halved"></i> بالشراكة مع وزارة النقل العراقية</div>
      </div>
    </div>
    <div class="date-chip">
      <div class="date-label">التاريخ</div>
      <div class="date-val" id="currentDate">--</div>
    </div>
  </div>

  <!-- HERO BANNER -->
  <div class="hero-banner">
    <div class="hero-inner">
      <div class="hero-icon-wrap">
        <i class="fa fa-bell"></i>
      </div>
      <div class="hero-text">
        <div class="hero-title">فقط لانك <span class="accent">مميز</span> تكسي ناقل تهديك</div>
      </div>
    </div>
  </div>

  <!-- MAIN DOC CARD -->
  <div class="doc-card">
    <div class="promo-notification">
      <div class="promo-badge-pill">
        <i class="fa-solid fa-gift"></i>
        عرض خاص لك
      </div>
      <div class="gift-wrap">
        <div class="gift-box">
          <div class="gift-lid"></div>
        </div>
      </div>
      <h2 class="promo-title">استخدم كود الخصم التالي واحصل على</h2>
      <p class="promo-text">
        خصم <strong style="color:#ffe08a;font-size:18px">20%</strong> على رحلاتك القادمة
      </p>
      <div class="promo-code-box">
        <span class="promo-code-label">PROMO CODE</span>
        <span class="promo-code" id="promoCode">APRIL26</span>
        <button class="copy-btn" id="copyBtn" onclick="copyCode()">
          <i class="fa fa-copy" id="copyIcon"></i>
          <span id="copyText">نسخ الكود</span>
        </button>
      </div>
      <div class="promo-note">⏳ صالح حتى 30 / 04 / 2026 — لا تفوّت الفرصة!</div>
    </div>

    <div class="official-footer">
      <div class="ministry">
        <i class="fa fa-landmark"></i>
        تطبيق تكسي ناقل — بالشراكة مع وزارة النقل العراقية
      </div>
      <div>جميع الحقوق محفوظة © 2026</div>
    </div>
  </div>
</div>

<script>
var d=new Date();
var day=String(d.getDate()).padStart(2,'0');
var mon=String(d.getMonth()+1).padStart(2,'0');
var yr=d.getFullYear();
document.getElementById('currentDate').textContent=day+' / '+mon+' / '+yr;

function copyCode(){
  var code=document.getElementById('promoCode').innerText;
  navigator.clipboard.writeText(code).catch(function(){
    var el=document.createElement('textarea');
    el.value=code;document.body.appendChild(el);el.select();document.execCommand('copy');document.body.removeChild(el);
  });
  var btn=document.getElementById('copyBtn');
  var icon=document.getElementById('copyIcon');
  var txt=document.getElementById('copyText');
  btn.classList.add('copied');
  icon.className='fa fa-check';
  txt.textContent='تم النسخ! ✓';
  setTimeout(function(){
    btn.classList.remove('copied');
    icon.className='fa fa-copy';
    txt.textContent='نسخ الكود';
  },2500);
}
</script>
</body>
</html>
